# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# From your Supabase project's Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Demo login list, format "username:password,username:password,..."
# These are meant to be public (see README) but still belong here, not hardcoded in source.
VITE_APP_USERS=person1:demo1234,person2:demo1234,person3:demo1234,person4:demo1234
